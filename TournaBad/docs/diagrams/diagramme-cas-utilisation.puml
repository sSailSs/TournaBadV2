@startuml
title TournaBad - Diagramme de cas d'utilisation

left to right direction
skinparam shadowing false

actor "Organisateur" as Organisateur
actor "Visiteur" as Visiteur

rectangle "TournaBad" {
  usecase "Se connecter" as UC0
  usecase "Creer un tournoi" as UC1
  usecase "Ajouter des joueurs" as UC2
  usecase "Generer un tour" as UC3
  usecase "Consulter les matchs" as UC4
  usecase "Saisir les scores" as UC5
  usecase "Voir le classement" as UC6
  usecase "Modifier les reglages\ndu tournoi" as UC7
  usecase "S'inscrire" as UC8
}

Organisateur --> UC0
Organisateur --> UC1
Organisateur --> UC2
Organisateur --> UC3
Organisateur --> UC4
Organisateur --> UC5
Organisateur --> UC6
Organisateur --> UC7

Visiteur --> UC0
Visiteur --> UC8

UC3 ..> UC1 : apres creation

@enduml
